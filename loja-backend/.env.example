PORT=3000

# Token secreto do Mercado Pago
MP_ACCESS_TOKEN=

# URL pública do frontend para retorno do checkout
FRONTEND_PUBLIC_URL=http://localhost:5173

# Origens permitidas no CORS (separe com vírgula)
FRONTEND_URLS=http://localhost:5173

# Webhook opcional do Mercado Pago
MP_WEBHOOK_URL=

# ─── Z-API (recomendado para Brasil) ────────────────────────────────────────
# Crie sua conta em https://z-api.io, crie uma instância e escaneie o QR Code
# Copie o Instance ID e o Token do painel da instância

# ID da instância Z-API (visível no painel)
ZAPI_INSTANCE_ID=

# Token da instância Z-API (visível no painel)
ZAPI_TOKEN=

# Client-Token de segurança (opcional, mas recomendado — em Segurança na Z-API)
ZAPI_CLIENT_TOKEN=

# ─── Webhook próprio / BotBot ───────────────────────────────────────────────
# Use quando quiser enviar via um integrador externo em vez de Z-API/Meta.
# O backend fará POST do payload padronizado para a URL abaixo.
WHATSAPP_CUSTOM_WEBHOOK_URL=

# Header opcional para autenticação do webhook externo
WHATSAPP_CUSTOM_WEBHOOK_AUTH_HEADER_NAME=Authorization
WHATSAPP_CUSTOM_WEBHOOK_AUTH_HEADER_VALUE=

# Credenciais do app criado no BotBot (incluídas no payload para seu integrador)
BOTBOT_API_BASE_URL=https://botbot.chat
BOTBOT_APP_KEY=
BOTBOT_AUTH_KEY=

# ─── WhatsApp Cloud API (Meta) — alternativa ────────────────────────────────
# Gere o token no Meta for Developers e mantenha apenas no backend
WHATSAPP_ACCESS_TOKEN=

# Exemplo atual: v23.0
WHATSAPP_API_VERSION=v23.0

# ID do número conectado no WhatsApp Business Platform
WHATSAPP_PHONE_NUMBER_ID=

# Opcional, usado para governança e diagnóstico
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Worker/Scheduler de automações WhatsApp ────────────────────────────────
# Liga o worker que varre Firestore e dispara mensagens automáticas
WHATSAPP_WORKER_ENABLED=false

# Intervalo entre execuções (ms). Exemplo: 60000 = 1 minuto
WHATSAPP_WORKER_INTERVAL_MS=60000

# Quantos dias para trás o worker deve considerar documentos elegíveis
WHATSAPP_WORKER_LOOKBACK_DAYS=21

# appId usado no caminho Firestore: artifacts/{appId}/public/data/...
WHATSAPP_WORKER_APP_ID=minha-loja-oficial

# Token opcional para proteger endpoints administrativos do worker
WHATSAPP_WORKER_ADMIN_TOKEN=

# Firebase Admin SDK (opção 1): JSON completo da service account em uma linha
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Admin SDK (opção 2): projectId (usado com credencial default)
FIREBASE_PROJECT_ID=